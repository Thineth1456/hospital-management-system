# Visual Studio / .NET ignore file
# See https://github.com/github/gitignore/blob/main/VisualStudio.gitignore for reference

# Build Folders
[Bb]in/
[Oo]bj/

# Visual Studio temporary files, build results, and
# files generated by popular Visual Studio add-ons.
*.user
*.suo
*.userosscache
*.sln.docstates
*.csproj.user
*.cache

# Visual Studio Code workspace settings
.vscode/

# Visual Studio hidden folder
.vs/

# NuGet packages
packages/
*.nupkg
project.lock.json
project.fragment.lock.json
artifacts/

# Resharper
_ReSharper*/
*.DotSettings.user

# Rider
.idea/
*.sln.iml

# Publish outputs
PublishProfiles/
*.Publish.xml

# Test results
TestResults/
*.trx

# SQL Server files
*.mdf
*.ldf
*.ndf

# Logs
*.log

# Node
node_modules/

# OS generated files
Thumbs.db
Desktop.ini
.DS_Store

# Other common
*.vspscc
*.vssscc

# Local app settings (uncommitted secrets)
appsettings.Development.json
appsettings.Local.json

# Sensitive or workspace-specific files
*.pfx
*.publishsettings

# Ignore package restore files
.nuget/

# Windows image file caches
ehthumbs.db

# Rider caches
.idea/

# Temporary files
*.tmp
*.temp

# Ignore files created by Visual Studio when debugging
*.log

# End of .gitignore
